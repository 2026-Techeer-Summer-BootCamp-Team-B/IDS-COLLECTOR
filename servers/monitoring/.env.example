# 이 파일을 .env로 복사한 뒤 실제 값을 채워서 사용한다.
# .env는 저장소 루트 .gitignore에 이미 포함되어 있으니 절대 커밋하지 말 것.

# ============================================================
# 호스트 바인딩 (방화벽 이중 방어용)
# ============================================================
# VM의 내부(사설) IP (예: 10.x.x.x). 내부 전용 Exporter들(Prometheus, Node
# Exporter, cAdvisor, Kafka Exporter, 그리고 아래의 향후 확장 Exporter 전부)은
# 0.0.0.0이 아니라 이 IP로만 게시한다 - GCP 방화벽 규칙이 잘못 설정되더라도
# 퍼블릭 NIC에서는 물리적으로 접근이 불가능하도록 하기 위함.
# 확인 방법: `hostname -I` (첫 번째 주소) 또는
# `curl -s -H "Metadata-Flavor: Google" http://metadata.google.internal/computeMetadata/v1/instance/network-interfaces/0/ip`
HOST_INTERNAL_IP=10.0.0.0

# ============================================================
# Grafana (외부(퍼블릭 NIC) 접근이 허용되는 유일한 서비스 - 3000번 포트)
# ============================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_before_deploy

# ============================================================
# Kafka Exporter (Phase 1)
# ============================================================
# kafka:9092 = siem-net 위의 BROKER 리스너 (servers/kafka/docker-compose.yml 참고).
# 이 리스너는 SASL/ACL이 전혀 설정되지 않은 PLAINTEXT라서 아직 만들어 둘 읽기
# 전용 계정 자체가 없다 - siem-net에 있는 누구든 이미 읽기/쓰기가 가능한 상태.
# 추후 Kafka에 SASL/ACL이 도입되면 그때 이 Exporter 전용 읽기 전용
# (Describe/Read만, Produce 불가) 계정을 만들 것.
KAFKA_EXPORTER_KAFKA_SERVER=kafka:9092

# ============================================================
# PostgreSQL Exporter
# 먼저 Postgres에 전용 읽기 전용 role을 만들어야 한다 (README 배포 절차 참고):
#   CREATE ROLE monitoring_ro WITH LOGIN PASSWORD '...' CONNECTION LIMIT 5;
#   GRANT pg_monitor TO monitoring_ro;
# ============================================================
POSTGRES_EXPORTER_HOST=postgres
POSTGRES_EXPORTER_PORT=5432
POSTGRES_EXPORTER_DB=ids_platform
POSTGRES_EXPORTER_USER=monitoring_ro
POSTGRES_EXPORTER_PASSWORD=CHANGE_ME_before_deploy

# ============================================================
# ClickHouse Exporter
# 먼저 전용 읽기 전용 계정을 만들어야 한다 (README 배포 절차 참고):
#   CREATE USER monitoring_ro IDENTIFIED WITH sha256_password BY '...';
#   GRANT SELECT ON system.* TO monitoring_ro;
# ============================================================
CLICKHOUSE_EXPORTER_HOST=clickhouse
CLICKHOUSE_EXPORTER_PORT=8123
CLICKHOUSE_EXPORTER_USER=monitoring_ro
CLICKHOUSE_EXPORTER_PASSWORD=CHANGE_ME_before_deploy

# ============================================================
# OpenSearch Exporter
# 참고: 기존 OpenSearch는 plugins.security.disabled=true로 떠 있어서
# (servers/datastore/opensearch/docker-compose.yml 참고) 현재는 읽기 전용
# 계정을 만들어 줄 인증 레이어 자체가 없다 - 그래서 URI만 있고 USER/PASSWORD가
# 없다. 나중에 security 플러그인이 켜지면 그때 전용 읽기 전용
# role(cluster:monitor/*, indices:monitor/*)을 만들고 exporter 설정에
# 인증정보를 추가할 것.
# ============================================================
OPENSEARCH_EXPORTER_URI=http://opensearch:9200

# ============================================================
# Blackbox Exporter
# 별도 인증정보 불필요 - blackbox/blackbox.yml에 정의된 HTTP(S)/TCP 엔드포인트를 프로빙.
# ============================================================

# ============================================================
# 향후 확장 (활성화 전까지 docker-compose.yml / prometheus.yml에서 주석 처리됨)
# ============================================================

# ---- Alertmanager ----
# ALERTMANAGER_SLACK_WEBHOOK_URL=
