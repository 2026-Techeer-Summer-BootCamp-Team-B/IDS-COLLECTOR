POSTGRES_USER=ids_admin
POSTGRES_PASSWORD=CHANGE_ME_dev
POSTGRES_DB=ids_platform

# init/005-seed-admin-user.sh가 최초 기동 시 이 값으로 admin 계정을 시드한다 - 없으면
# 시드를 건너뛰고 경고만 남긴다(하드코딩된 기본 비밀번호 없음).
ADMIN_INITIAL_PASSWORD=CHANGE_ME_dev

# init/031-seed-demo-account.sh가 최초 기동 시 이 값으로 공개 데모 계정(username:
# demo, role: admin)을 시드한다 - 대시보드의 "로그인 없이 둘러보기" 버튼이 이
# 계정으로 자동 로그인한다. dashboard/.env의 VITE_DEMO_PASSWORD와 반드시 같은
# 값이어야 한다. 값이 없으면 시드를 건너뛰고 버튼도 숨겨진다 - 평가/테스트
# 환경이 아니면 비워둘 것(이 계정은 admin 권한이라 프론트엔드 번들에 자격증명이
# 그대로 노출된다).
DEMO_ACCOUNT_PASSWORD=CHANGE_ME_demo
