{
  "index_patterns": ["attack-logs-*"],
  "template": {
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "event": {
          "properties": {
            "id": { "type": "keyword" },
            "module": { "type": "keyword" },
            "dataset": { "type": "keyword" },
            "kind": { "type": "keyword" },
            "action": { "type": "keyword" },
            "outcome": { "type": "keyword" },
            "severity": { "type": "integer" },
            "duration": { "type": "long" },
            "original": { "type": "text" },
            "ingested": { "type": "date" }
          }
        },
        "rule": {
          "properties": {
            "id": { "type": "keyword" },
            "name": { "type": "keyword" }
          }
        },
        "source": {
          "properties": {
            "ip": { "type": "ip" },
            "geo": {
              "properties": {
                "country_iso_code": { "type": "keyword" },
                "city_name": { "type": "keyword" }
              }
            }
          }
        },
        "user": {
          "properties": {
            "name": { "type": "keyword" }
          }
        },
        "orchestrator": {
          "properties": {
            "namespace": { "type": "keyword" },
            "resource": {
              "properties": {
                "type": { "type": "keyword" },
                "name": { "type": "keyword" }
              }
            }
          }
        },
        "container": {
          "properties": {
            "name": { "type": "keyword" },
            "id": { "type": "keyword" },
            "image": {
              "properties": {
                "name": { "type": "keyword" }
              }
            }
          }
        },
        "http": {
          "properties": {
            "request": {
              "properties": {
                "method": { "type": "keyword" },
                "referrer": { "type": "keyword" }
              }
            },
            "response": {
              "properties": {
                "status_code": { "type": "integer" },
                "body": {
                  "properties": {
                    "bytes": { "type": "long" }
                  }
                }
              }
            }
          }
        },
        "url": {
          "properties": {
            "path": { "type": "keyword" },
            "query": { "type": "keyword" }
          }
        },
        "user_agent": {
          "properties": {
            "original": { "type": "text" }
          }
        },
        "waf": {
          "properties": {
            "risk_level": { "type": "keyword" },
            "payload_snippet": { "type": "text" },
            "blocked": { "type": "boolean" },
            "mode": { "type": "keyword" }
          }
        },
        "process": {
          "properties": {
            "name": { "type": "keyword" },
            "command_line": { "type": "text" },
            "parent": {
              "properties": {
                "name": { "type": "keyword" }
              }
            }
          }
        },
        "falco": {
          "properties": {
            "priority": { "type": "keyword" },
            "tags": { "type": "keyword" }
          }
        },
        "kubernetes": {
          "properties": {
            "audit": {
              "properties": {
                "stage": { "type": "keyword" },
                "verb": { "type": "keyword" },
                "user": {
                  "properties": {
                    "groups": { "type": "keyword" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
