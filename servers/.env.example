GEMINI_API_KEY=

# servers/docker-compose.yml의 POSTGRES_DSN(correlation-engine/platform-api)이
# ${POSTGRES_PASSWORD}로 참조한다 - servers/datastore/postgres/.env의
# POSTGRES_PASSWORD와 반드시 같은 값이어야 한다(별도 docker-compose 프로젝트라
# .env를 공유할 수 없어서 두 곳에 따로 둠).
POSTGRES_PASSWORD=CHANGE_ME_dev

# servers/docker-compose.yml의 platform-api가 ${CLICKHOUSE_PASSWORD}로 참조한다 -
# servers/datastore/clickhouse/.env의 CLICKHOUSE_PASSWORD와 반드시 같은 값이어야
# 한다(마찬가지로 별도 프로젝트라 .env 공유 불가).
CLICKHOUSE_PASSWORD=CHANGE_ME_dev
