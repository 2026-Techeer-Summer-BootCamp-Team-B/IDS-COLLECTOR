GEMINI_API_KEY=

# servers/docker-compose.yml의 POSTGRES_DSN(correlation-engine/platform-api)이
# ${POSTGRES_PASSWORD}로 참조한다 - servers/datastore/postgres/.env의
# POSTGRES_PASSWORD와 반드시 같은 값이어야 한다(별도 docker-compose 프로젝트라
# .env를 공유할 수 없어서 두 곳에 따로 둠).
POSTGRES_PASSWORD=CHANGE_ME_dev

# servers/docker-compose.yml의 platform-api가 ${CLICKHOUSE_PASSWORD}로 참조한다 -
# servers/datastore/clickhouse/.env의 CLICKHOUSE_PASSWORD와 반드시 같은 값이어야
# 한다(마찬가지로 별도 프로젝트라 .env 공유 불가).
CLICKHOUSE_PASSWORD=CHANGE_ME_dev

# 게이트웨이 시크릿(감사 S13, 2026-07-16 - docs/reports/high-patch-20260716.md).
# servers/docker-compose.yml에서 두 군데가 이 값을 같이 참조한다:
#   1) platform-api 서비스의 Traefik 라우터 라벨(platform-api-gateway-secret
#      headers 미들웨어)이 이 값을 X-Internal-Gateway-Secret 요청 헤더로 주입
#   2) platform-api 컨테이너 자신도 같은 값을 INTERNAL_GATEWAY_SECRET env로 받아
#      app/auth.py의 verify_gateway_secret()에서 비교
# 라벨과 컨테이너 env 둘 다 같은 servers/docker-compose.yml 프로젝트(=이 .env) 안에
# 있어서 servers/proxy/.env 같은 별도 파일이 필요 없다(다른 시크릿들과 달리 이건
# Traefik 컨테이너 자체가 아니라 platform-api 서비스에 붙은 라벨이 쓰기 때문).
# openssl rand -hex 32 등으로 생성할 것 - 실제 배포에서는 반드시 CHANGE_ME_dev가
# 아닌 값으로 교체(안 바꾸면 siem-net 내부의 직접 접근 방어가 무력화됨).
INTERNAL_GATEWAY_SECRET=CHANGE_ME_dev
