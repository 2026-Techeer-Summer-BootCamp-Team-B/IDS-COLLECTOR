# dashboard/.env.example — copy to dashboard/.env and adjust for local dev.
# Vite only exposes VITE_-prefixed vars to the browser (import.meta.env).

# servers/platform-api API base URL. See repo root README.md의
# "프론트엔드 연동 API" 절.
#
# 기본값(비워두면) "/api" — 대시보드가 Traefik 뒤에 sibling 서비스로 같이
# 떠 있을 때(같은 origin) 맞는 값. `npm run dev`로 대시보드만 따로 띄워서
# 개발할 때는 아래 둘 중 하나로 지정할 것:
#
#   Traefik 경유(:80, 실제 배포 경로와 동일):
# VITE_API_BASE_URL=http://localhost/api
#
#   platform-api 직결(:8400, 디버깅용 — README 포트 표 참고. servers/docker-compose.yml에서
#   호스트 127.0.0.1에만 바인딩되어 있으므로, 원격(GCP VM 등) docker 호스트를 쓸 때는
#   SSH 터널이 필요하다: ssh -L 8400:localhost:8400 <host>):
# VITE_API_BASE_URL=http://localhost:8400

# Vercel 배포 시(2026-07-16) — 대시보드가 더 이상 Traefik 뒤 sibling 서비스가
# 아니라 완전히 다른 origin(*.vercel.app)에서 서빙되므로 "/api" 기본값이 더는
# 안 맞는다. Vercel 프로젝트 Settings → Environment Variables에 아래 키로
# 백엔드 절대 URL을 등록할 것 (이 파일이 아니라 Vercel 대시보드에 — IP가 바뀔 수
# 있고, 이 값 자체는 비밀도 아니지만 배포 환경마다 값이 다르므로 git에는 안 커밋한다):
#
#   VITE_API_BASE_URL=http://<GCP-VM-IP-또는-도메인>/api
#
# 주의: Vercel은 항상 HTTPS로 서빙하는데 백엔드가 아직 IP:80(평문 HTTP)이면
# 브라우저의 mixed-content 정책 때문에 fetch가 막힌다(HTTPS 페이지 → HTTP
# API 호출 차단). 백엔드에 TLS(도메인 + Traefik ACME)가 붙기 전까지는 Vercel
# 프리뷰 URL에서 실제 로그인/API 호출 테스트가 안 될 수 있음 — 이건 프론트
# 설정 문제가 아니라 백엔드 TLS가 선행돼야 풀리는 별개 이슈다.

# 대시보드가 시간을 표시할 때 쓰는 타임존(src/lib/timezone.js). 기본값(비워두면)
# "Asia/Seoul" - 배포 서버 타임존에 맞추려면 IANA 타임존 이름으로 지정할 것
# (예: UTC, Asia/Seoul, America/New_York).
# VITE_DISPLAY_TIMEZONE=Asia/Seoul
