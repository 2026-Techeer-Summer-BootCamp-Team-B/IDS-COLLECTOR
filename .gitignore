venv/
.venv/
__pycache__/
*.pyc
.env
.DS_Store
build/
*.egg-info/
.pytest_cache/

# Traefik의 ACME(Let's Encrypt) 상태 파일 - 계정 개인키/발급된 인증서가 그대로
# 담기는 런타임 시크릿이라 절대 커밋하면 안 된다(2026-07-17, 실수로 이미 한 번
# 커밋됐던 걸 발견해서 추가 - 서버에서 git rm --cached로 추적 해제하고, 가능하면
# git 히스토리에서도 제거 + Let's Encrypt 계정 키 재발급을 권장).
servers/proxy/traefik/letsencrypt/

# otlp-grpc mTLS CA/클라이언트 인증서 - generate-otlp-mtls-certs.sh가 생성하는
# 개인키(ca.key/client.key)와 인증서. otlp-client-ca.crt(공개 CA 인증서)만 예외로
# 커밋 가능하지만, 실수 방지를 위해 디렉터리 전체를 무시하고 스크립트만 별도 추적한다.
servers/proxy/traefik/certs/*
!servers/proxy/traefik/certs/generate-otlp-mtls-certs.sh
